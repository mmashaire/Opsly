# Optional backend mode. Use "postgres" to persist data in PostgreSQL.
# Leave unset (or set to "memory") for in-memory storage.
OPSLY_DATA_BACKEND=memory

# Required only when OPSLY_DATA_BACKEND=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opsly

# Optional auth tokens for role resolution via Authorization: Bearer <token>
# Leave unset unless you plan to use bearer-token auth locally.
# When set, use unique per-environment values rather than shared defaults.
OPSLY_ADMIN_TOKEN=
OPSLY_VIEWER_TOKEN=

# Optional comma-separated origins allowed to call the API from a browser.
# Example for local frontend development:
# OPSLY_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
OPSLY_ALLOWED_ORIGINS=

# Authentication mode for role resolution.
# Default behavior (when unset) is bearer-only mode, which ignores x-opsly-role.
# Set to role-header only for local demo/testing convenience.
# OPSLY_AUTH_MODE=role-header
OPSLY_AUTH_MODE=
