# Optional backend mode. Use "postgres" to persist data in PostgreSQL.
# Leave unset (or set to "memory") for in-memory storage.
OPSLY_DATA_BACKEND=memory

# Required only when OPSLY_DATA_BACKEND=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opsly

# Optional auth tokens for role resolution via Authorization: Bearer <token>
# These should be unique per environment.
OPSLY_ADMIN_TOKEN=opsly-admin-dev-token
OPSLY_VIEWER_TOKEN=opsly-viewer-dev-token
